# Provider secrets (admin-only; never committed).
# NOTE: on Vercel these are pushed as SENSITIVE (write-only) env vars — they work at runtime but
# CANNOT be read back via `vercel env pull` or the dashboard (by design). So for LOCAL provider
# testing you must paste the current keys here yourself; a `vercel env pull` returns them blank.
# The canonical Apollo/Clearout/Freshsales verification is `npm run e2e:prod` against the deployed
# worker (which holds the live keys) — not local calls. APOLLO_API_KEY in particular must have
# People-Search scope (a key valid only for auth/health will 401 on search).
FRESHSALES_API_KEY=
FRESHSALES_ORG_DOMAIN=mordorintelligence
APOLLO_API_KEY=
CLEAROUT_BASE_URL=https://api.clearout.io
CLEAROUT_API_TOKEN=

# Day AI integration user (provisioned as harsha@ask-myra.ai)
DAY_AI_CLIENT_ID=
DAY_AI_CLIENT_SECRET=
DAY_AI_AUTH_BASE=https://day.ai
DAY_AI_MCP_BASE=https://day.ai/api/mcp
# Refresh token persisted by worker-dayai-onboard.mjs to worker/.secrets/day-ai-refresh.json
# DAY_AI_INTEGRATION_TOKEN can override the refresh-token path for short-lived service tokens

# Day AI workspace IDs (pipelines + stages). Source of truth: templates/day-ai-workspace-ids.json.
# These are populated AFTER the AM team creates the two pipelines (New Business + Expansion)
# in the Day.ai UI. Callers (backfill script, Codex MCP assistant) resolve them from
# workspace-ids.json before invoking dayai_write — worker handler does not read these directly,
# they're listed here so production deploys know which env vars to set.
DAY_AI_PIPELINE_NEW_BUSINESS_OUTBOUND_ID=d5cecc36-4757-4e60-8d66-900ef7a475af
DAY_AI_PIPELINE_EXPANSION_ID=edd86bbc-fd6c-4307-993f-6d1a6ba968aa
DAY_AI_STAGE_CONNECTION_ID=557bc92f-216f-4812-a622-18ce27a9d0a3
DAY_AI_STAGE_DISCOVERY_ID=3bd23208-e9b5-4264-99ba-d3cbc158f7fb
DAY_AI_STAGE_DEMO_WALKTHROUGH_ID=d95c83f1-5ec6-4ced-85bb-56f997c14a0f
DAY_AI_STAGE_TRIAL_ACTIVE_ID=dea39fa7-4a45-48f3-acd7-815f045bab20
DAY_AI_STAGE_NEGOTIATION_ID=276360a5-8489-4fb3-9218-51e6af82f6cf
DAY_AI_STAGE_NB_CLOSED_WON_ID=5ce9e472-1da8-493d-81e0-cc8edad90ee8
DAY_AI_STAGE_NB_CLOSED_LOST_ID=71986b2c-da91-4e52-b3a3-d95f529c1f7c
DAY_AI_STAGE_TRIAL_TO_PAID_ID=cd9e5f34-f38b-49b1-98da-fe11745ea3ba
DAY_AI_STAGE_ADOPTION_ID=51f9d088-8883-408a-af1f-57d26553c6e1
DAY_AI_STAGE_UPSELL_IDENTIFIED_ID=6380d25f-89e4-4544-8aed-35880d200c22
DAY_AI_STAGE_RENEWAL_HOLD_ID=5f2c7f52-73e4-4cfa-84a4-3636f907d701
DAY_AI_STAGE_EXP_CLOSED_WON_ID=7ece9a16-d182-48ad-addd-7325469d1d69
DAY_AI_STAGE_EXP_CLOSED_LOST_ID=f6dafd45-672d-42f5-8562-dc2657278049
DAY_AI_STAGE_CHURNED_ID=fd9bee04-b96b-4bd3-8386-38bace3f7528

# Worker bearer tokens (one per AM email). Format: comma-separated "email:token" pairs.
# Example: WORKER_BEARER_TOKENS=satya@ask-myra.ai:tok_satya_xxx,satish@ask-myra.ai:tok_satish_xxx
WORKER_BEARER_TOKENS=

# Worker store location (sqlite-free disk-backed JSON store in v1)
WORKER_STORE_DIR=worker/data

# Listen port
PORT=8787
