{
  "$schema": "../schemas/contact-sourcing.schema.json",
  "centralizedConnector": {
    "enabled": true,
    "keyOwner": "admin_runtime",
    "amKeysRequired": false,
    "requestPolicy": "am_can_request_provider_actions_codex_routes_to_central_connector",
    "fallbackWhenUnavailable": "create_day_ai_connector_request_or_pause_for_admin"
  },
  "providers": {
    "freshsales": {
      "enabled": true,
      "mode": "centralized_read_only",
      "secretScope": "admin_local",
      "purpose": "Existing CRM evidence, activity, account/contact/deal context",
      "amVisible": true
    },
    "apollo": {
      "enabled": true,
      "mode": "centralized_am_requested",
      "secretScope": "admin_local",
      "purpose": "Net-new contact sourcing and selective enrichment",
      "amVisible": true,
      "defaultSearchLimitPerAccount": 25,
      "enrichmentPolicy": "selective_only"
    },
    "clearout": {
      "enabled": true,
      "mode": "centralized_am_requested_verification",
      "secretScope": "admin_local",
      "purpose": "Selective email verification for enriched or imported candidate emails",
      "amVisible": true,
      "verificationPolicy": "verify_selected_or_enriched_emails_only"
    }
  },
  "approvalRules": {
    "createDayAiPerson": "am_approval_required",
    "apolloEnrichment": "admin_or_credit_approval_required",
    "clearoutVerification": "admin_or_credit_approval_required",
    "externalSend": "never_automatic"
  },
  "rawSnapshotPolicy": {
    "storeNormalizedFields": true,
    "storeRedactedRawSnapshot": true,
    "redactKeys": ["api_key", "token", "authorization", "cookie", "personal_phone", "mobile_phone"],
    "dayAiStorage": "account_context_source_trail"
  }
}
