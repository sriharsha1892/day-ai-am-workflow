{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://myra.ai/schemas/contact-sourcing.schema.json",
  "title": "myRA Contact Sourcing Config",
  "type": "object",
  "additionalProperties": false,
  "required": ["providers", "approvalRules", "rawSnapshotPolicy"],
  "properties": {
    "centralizedConnector": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled", "keyOwner", "amKeysRequired", "requestPolicy", "fallbackWhenUnavailable"],
      "properties": {
        "enabled": { "type": "boolean" },
        "keyOwner": { "type": "string" },
        "amKeysRequired": { "type": "boolean" },
        "requestPolicy": { "type": "string" },
        "fallbackWhenUnavailable": { "type": "string" }
      }
    },
    "leadIdentificationOrder": {
      "type": "array",
      "items": {
        "enum": [
          "imported_active_contacts",
          "apollo_search",
          "freshsales_mi_evidence",
          "day_ai_existing_people",
          "clearout_selected_verification"
        ]
      },
      "minItems": 1
    },
    "providers": {
      "type": "object",
      "additionalProperties": false,
      "required": ["freshsales", "apollo", "clearout"],
      "properties": {
        "freshsales": { "$ref": "#/$defs/provider" },
        "apollo": { "$ref": "#/$defs/provider" },
        "clearout": { "$ref": "#/$defs/provider" }
      }
    },
    "approvalRules": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "rawSnapshotPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["storeNormalizedFields", "storeRedactedRawSnapshot", "redactKeys", "dayAiStorage"],
      "properties": {
        "storeNormalizedFields": { "type": "boolean" },
        "storeRedactedRawSnapshot": { "type": "boolean" },
        "redactKeys": { "type": "array", "items": { "type": "string" } },
        "dayAiStorage": { "type": "string" }
      }
    }
  },
  "$defs": {
    "provider": {
      "type": "object",
      "additionalProperties": true,
      "required": ["enabled", "mode", "secretScope", "purpose"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string" },
        "secretScope": { "type": "string" },
        "purpose": { "type": "string" }
      }
    }
  }
}
