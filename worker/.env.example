# Provider secrets (admin-only; never committed)
FRESHSALES_API_KEY=
FRESHSALES_ORG_DOMAIN=mordorintelligence
APOLLO_API_KEY=
CLEAROUT_BASE_URL=https://api.clearout.io
CLEAROUT_API_TOKEN=

# Day AI integration user (provisioned as harsha@ask-myra.ai)
DAY_AI_CLIENT_ID=
DAY_AI_CLIENT_SECRET=
DAY_AI_AUTH_BASE=https://day.ai
DAY_AI_MCP_BASE=https://day.ai/api/mcp
# Refresh token persisted by worker-dayai-onboard.mjs to worker/.secrets/day-ai-refresh.json
# DAY_AI_INTEGRATION_TOKEN can override the refresh-token path for short-lived service tokens

# Worker bearer tokens (one per AM email). Format: comma-separated "email:token" pairs.
# Example: WORKER_BEARER_TOKENS=satya@ask-myra.ai:tok_satya_xxx,satish@ask-myra.ai:tok_satish_xxx
WORKER_BEARER_TOKENS=

# Worker store location (sqlite-free disk-backed JSON store in v1)
WORKER_STORE_DIR=worker/data

# Listen port
PORT=8787
