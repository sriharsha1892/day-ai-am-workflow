{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60
    },
    "api/mcp.mjs": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/mcp", "destination": "/api/mcp" },
    { "source": "/mcp/(.*)", "destination": "/api/mcp" },
    { "source": "/(.*)", "destination": "/api" }
  ]
}
